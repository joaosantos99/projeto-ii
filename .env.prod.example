# Copy to .env on the Hetzner server (docker compose reads it).
# docker-compose.prod.yml interpolates these.

# Public domain (Caddy auto-TLS via Let's Encrypt)
DOMAIN=app.cm-viladoconde.pt
# Admin subdomain — must have its own DNS A-record → server IP
ADMIN_DOMAIN=admin.cm-viladoconde.pt
# API subdomain — must have its own DNS A-record → server IP
API_DOMAIN=api.cm-viladoconde.pt
ACME_EMAIL=admin@cm-viladoconde.pt

# Database (mysql service)
DB_NAME=projeto_ii
DB_USER=mysql_user
DB_PASSWORD=change_me_strong

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=yourpassword
SMTP_FROM=no-reply@cm-viladoconde.pt
