{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "test": "vitest run --exclude='**/tests/integration/**'",
    "test:integration": "vitest run src/tests/integration",
    "test:all": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint src",
    "lint:fix": "biome lint src --fix",
    "db:migrate": "bun src/database/migrate.js",
    "db:migrate:undo": "bun src/database/migrate.js --down",
    "db:seed:prod": "bun seed.prod.js",
    "db:create-migration": "sequelize migration:generate --name "
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1061.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ioredis": "^5.11.0",
    "multer": "^2.1.1",
    "mysql2": "^3.19.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "resend": "^6.12.4",
    "sequelize": "^6.37.8",
    "swagger-ui-express": "^5.0.1",
    "umzug": "^3.8.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@faker-js/faker": "^10.4.0",
    "@testcontainers/mysql": "^12.0.1",
    "nodemon": "^3.1.14",
    "sequelize-cli": "^6.6.5",
    "vitest": "^4.1.7"
  }
}
